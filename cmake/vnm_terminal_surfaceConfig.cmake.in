@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(VNM_TERMINAL_SURFACE_QT_PRIVATE_API_VERSION_MAJOR
    "@VNM_TERMINAL_SURFACE_QT_PRIVATE_API_VERSION_MAJOR@")
set(VNM_TERMINAL_SURFACE_QT_PRIVATE_API_VERSION_MINOR
    "@VNM_TERMINAL_SURFACE_QT_PRIVATE_API_VERSION_MINOR@")
set(VNM_TERMINAL_SURFACE_MSDF_TEXT_RENDERER_ENABLED
    "@VNM_TERMINAL_ENABLE_MSDF_TEXT_RENDERER@")

find_dependency(Qt6
    "${VNM_TERMINAL_SURFACE_QT_PRIVATE_API_VERSION_MAJOR}.${VNM_TERMINAL_SURFACE_QT_PRIVATE_API_VERSION_MINOR}"
    COMPONENTS Core Gui Quick QuickPrivate GuiPrivate)

if(VNM_TERMINAL_SURFACE_MSDF_TEXT_RENDERER_ENABLED)
    find_dependency(vnm_msdf_text CONFIG)
endif()

if((NOT "${Qt6_VERSION_MAJOR}" STREQUAL "${VNM_TERMINAL_SURFACE_QT_PRIVATE_API_VERSION_MAJOR}") OR
    (NOT "${Qt6_VERSION_MINOR}" STREQUAL "${VNM_TERMINAL_SURFACE_QT_PRIVATE_API_VERSION_MINOR}"))
    message(FATAL_ERROR
        "vnm_terminal_surface was built against Qt "
        "${VNM_TERMINAL_SURFACE_QT_PRIVATE_API_VERSION_MAJOR}."
        "${VNM_TERMINAL_SURFACE_QT_PRIVATE_API_VERSION_MINOR}.x private APIs, "
        "but this consumer resolved Qt ${Qt6_VERSION}. Use the same Qt minor "
        "or rebuild vnm_terminal_surface from source.")
endif()

include("${CMAKE_CURRENT_LIST_DIR}/vnm_terminal_surfaceTargets.cmake")

check_required_components(vnm_terminal_surface)
